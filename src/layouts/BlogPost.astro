---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, kidsVersion, detailVersion } =
	Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.hero-image {
				width: 100%;
				margin-top: 2rem;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 16px;
				box-shadow: 0 6px 24px rgba(45, 110, 79, 0.15);
			}
			.prose {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: 2rem auto 4rem;
				padding: 2rem;
				background: var(--brand-card);
				border-radius: 16px;
				border: 1px solid var(--brand-border);
				color: var(--text-main);
				line-height: 1.85;
				box-shadow: 0 4px 14px rgba(45, 110, 79, 0.06);
			}
			.title {
				margin-bottom: 1.5em;
				padding-bottom: 1em;
				border-bottom: 2px dashed var(--brand-border);
			}
			.title h1 {
				margin: 0;
				font-size: 1.8rem;
				color: var(--brand-green-dark);
				line-height: 1.4;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--text-muted);
				font-size: 0.9rem;
			}
			.last-updated-on {
				font-style: italic;
			}
			.pair-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				margin: 0.75rem 0 1.25rem;
				padding: 0.7rem 1.2rem;
				background: var(--brand-green-soft);
				border: 1.5px solid var(--brand-green-light);
				border-radius: 999px;
				color: var(--brand-green-dark);
				text-decoration: none;
				font-weight: 700;
				font-size: 0.92rem;
				transition: 0.2s ease;
			}
			.pair-link:hover {
				background: var(--brand-green);
				color: #faf7ee;
				transform: translateY(-1px);
				text-decoration: none;
			}
			.pair-link .emoji {
				font-size: 1.2em;
			}
			@media (max-width: 720px) {
				.prose {
					padding: 1.2rem;
				}
				.title h1 {
					font-size: 1.4rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					{
						kidsVersion && (
							<a class="pair-link" href={`${base}blog/${kidsVersion}/`}>
								<span class="emoji">🧒</span>
								小学生でもわかるやさしい版はこちら →
							</a>
						)
					}
					{
						detailVersion && (
							<a class="pair-link" href={`${base}blog/${detailVersion}/`}>
								<span class="emoji">📖</span>
								大人向けの詳しい版はこちら →
							</a>
						)
					}
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
